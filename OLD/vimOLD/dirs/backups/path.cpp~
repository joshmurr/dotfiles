#include "path.h"

Path::Path(){
}

void Path::addPoint(float x, float y){
    ofVec2f point(x, y);
    points.push_back(point);
}

void Path::setup(int rad){
    radius = rad;

    float thirdWidth = ofGetWidth()/3;
    float thirdHeight = ofGetHeight()/3;

    addPoint(0, thirdHeight);
    addPoint(thirdWidth, ofRandom(0,ofGetHeight()));
    addPoint(thirdWidth*2, ofRandom(0,ofGetHeight()));
    addPoint(ofGetWidth(), thirdHeight*2);

    for(ofVec2f p : points){
        ofPoint pt;
        pt.set(p.x, p.y);
        thickLine.addVertex(pt);
        thinLine.addVertex(pt);
    }
}


void Path::draw(){
    ofSetLineWidth(radius*2);
    ofSetColor(0, 100);
    thickLine.draw();
    ofSetLineWidth(1);
    ofSetColor(0);
    thinLine.draw();
}
