@app.route('/delete', methods=['GET'])
def delete():
    # DELETE
    errors = []
    from models import Result
    try:
        print("DELETING {}".format(request.args.get("item")))
        to_delete = Result.query.filter_by(id=request.args.get("id")).first()
        db.session.delete(to_delete)
        db.session.commit()
        return redirect('/display')
    except:
        for error in sys.exc_info():
            errors.append("Error: {}".format(error))
        return jsonify(errors)


@app.route('/get_all_entries', methods=['GET', 'POST'])
def display_all():
    from models import Result
    errors = []
    # Fetch things from db
    try:
        results = Result.query.all()
        ret = [result.serialize_full() for result in results]
        return jsonify(ret)
    except:
        for error in sys.exc_info():
            errors.append("Error: {}".format(error))
        return jsonify(errors)


