#ifdef GL_ES
precision mediump float;
#endif

#define PI 3.14159265359

uniform vec2 u_mouse;
uniform vec2 u_resolution;
uniform float u_time;


vec3 red = vec3(1.0, 0.0, 0.0);
vec3 green = vec3(0.0, 1.0, 0.0);
vec3 blue = vec3(0.0, 0.0, 1.0);

void main(){
   vec2 p = gl_FragCoord.xy / u_resolution.xy; // Current Pixel/Frag 

   // Background
   vec3 gradient = vec3(p.y);
   gradient.r = smoothstep(0.1, 0.5, p.y);
   gradient.g = sin(p.y * PI * 1.5);
   gradient.b = pow(p.x, 2.2);

   vec3 o = mix(red, blue, gradient);
   

   // Sun thing
   vec2 q = p - vec2(0.5, 0.5);
   float r = 0.35;
   r += 0.01*cos(u_time*4.0 + atan(q.y, q.x)*10.0);

   float c = 1.0 - (smoothstep(r, r+0.08, length(q)));

   o += 0.8* mix(o, blue, c);


   gl_FragColor = vec4(o, 1.0);
}
