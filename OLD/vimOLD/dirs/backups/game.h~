#ifndef SRC_GAME_H_
#define SRC_GAME_H_

#include "screen.h"
#include "rect.h"

struct Cell {
   int x, y, w, h;
    int color;
};

class Game {
private:
	int width, height;
    int cell_size;
    int cols, rows;
    int total_cells;
	Cell *m_cells;
    Cell *m_cells_buffer;
	int lastTime;
public:
	Game(const int cs, const int w, const int h);
	virtual ~Game();
	void update(int elapsed);

	Cell *getCells() {
		return m_cells;
	}

    int getRows() {
        return rows;
    }
    int getCols() {
        return cols;
    }
};


#endif /* SRC_GAME_H_ */
