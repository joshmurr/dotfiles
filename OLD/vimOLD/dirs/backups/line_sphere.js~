function line_sphere(){
    var fov = 400;

    let line_sphere_canvas = document.getElementById("line_sphere");
    let line_sphere_canvas_width = 800;
    let line_sphere_canvas_height = 600;
    var context = line_sphere_canvas.getContext("2d");
    line_sphere_canvas.setAttribute("width",line_sphere_canvas_width);
    line_sphere_canvas.setAttribute("height",line_sphere_canvas_height);
    //canvas.addEventListener('mousemove',getMouse,false);
    var mouseX=0;
    var mouseY=0;

    var point = [];
    var points = [];
    var point3d = [];
    var angleX = 0;
    var angleY = 0;
    var HALF_WIDTH =line_sphere_canvas_width / 2;
    var HALF_HEIGHT =line_sphere_canvas_height / 2;

    var x3d = 0;
    var y3d = 0;
    var z3d = 0;

    var lastScale = 0;
    var lastx2d = 0;
    var lasty2d = 0;
    var dim = 20; // This is the number of rings
    var spacing = ((Math.PI * 2) / dim);
    var numPoints = dim * dim;
    var size = 200;
    var ticks = 0;

    // MAKE POINTS
    for (var i = 0; i < dim ; i++) {
        var z = size * Math.cos(spacing / 2 * i);
        var s = size * Math.sin(spacing / 2 * i);
        for (var j = 0; j < dim; j++ ) {
            var point = [Math.cos(spacing * j) * s,Math.sin(spacing * j) * s,z];
            points.push(point);

        }
    }

    function draw() {
        context.fillStyle = "rgb(0,0,0)";
        context.fillRect(0, 0,line_sphere_canvas_width,line_sphere_canvas_height);

        angleX=((mouseX/line_sphere_canvas_width)-0.5)/4;
        angleY=((mouseY/line_sphere_canvas_height)-0.5)/4;

        var prevPoint = [];
        var prevScale;

        for (let i = 0; i < dim ; i++) {
            // For each RING
            var firstPoint = [];
            var firstScale;
            var color = Math.floor((255/dim)*i);
            context.strokeStyle = "rgb("+(255-color)+",255,"+color+")";
            context.beginPath();
            for (let j = 0; j < dim; j++ ) {
                // For each SEGMENT
                point3d = points[j+dim*i];
                z3d = point3d[2];
                //z3d -= 1;
                if (z3d < -fov) z3d += 10;
                point3d[2] = z3d;

                rotateX(point3d,0.01);
                rotateY(point3d,0.01);

                x3d = point3d[0];
                y3d = point3d[1];
                z3d = point3d[2];

                var scale = (fov / (fov + z3d));

                var x2d = (x3d * scale) + HALF_WIDTH;
                var y2d = (y3d * scale) + HALF_HEIGHT;

                if(!j) {
                    firstPoint = [x2d, y2d]; // Save first point
                    firstScale = scale;
                }

                context.lineWidth = scale;
                context.lineTo(x2d + scale, y2d);
            }
            context.lineTo(firstPoint[0] + firstScale, firstPoint[1]);
            context.stroke();
        }

        /*for (let i = 0; i < dim ; i++) {

          for (let j = 0; j < dim; j++ ) {
            let point = points[i+j*dim];
            point[0] += Math.cos(ticks/4)*10;
            point[1] += Math.sin(ticks/4)*10;
            point[2] += Math.cos(ticks/4)*10;

          }
        }

        ticks++;
        */

        requestAnimationFrame(draw);
    }

    requestAnimationFrame(draw);


    function rotateX(point3d,angleX) {
        var	x = point3d[0]; 
        var	z = point3d[2]; 

        var	cosRY = Math.cos(angleX);
        var	sinRY = Math.sin(angleX);

        var	tempz = z; 
        var	tempx = x;

        x= (tempx*cosRY)+(tempz*sinRY);
        z= (tempx*-sinRY)+(tempz*cosRY);

        point3d[0] = x;
        point3d[2] = z;

    }

    function rotateY(point3d,angleY) {
        var y = point3d[1];
        var	z = point3d[2]; 

        var cosRX = Math.cos(angleY);
        var sinRX = Math.sin(angleY);

        var	tempz = z; 
        var	tempy = y;

        y= (tempy*cosRX)+(tempz*sinRX);
        z= (tempy*-sinRX)+(tempz*cosRX);

        point3d[1] = y;
        point3d[2] = z;

    }
}
line_sphere();

