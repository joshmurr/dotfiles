window.onload = function() {
			var canvas = document.getElementById("canvas"),
				context = canvas.getContext("2d"),
				width = canvas.width = window.innerWidth,
				height = canvas.height = window.innerHeight,
				cols = 20,
				rows = 10,
				arrows = [],
				letters = ['J','O','S','H','M','U','R','R'],
				lw = 30,
				lh = 60;
		
			init();
			globalRender();
		
			function init(){
				for(var i=0; i<rows; i++){
					for(var ii=0; ii<cols; ii++){
						//arrows.push(new arrow(i*cols,ii*rows,letters[Math.round(Math.random()*8)]));

                        xloc = (ii * (width/cols)) + ((width/cols)/2);
                        yloc = (i * (height/rows)) + ((height/rows)/2);
                        //console.log('Arrow: ' + i+ii + ', xloc: ' + xloc + ', yloc: ' + yloc);
						arrows.push(new arrow(xloc,yloc, letters[Math.round(Math.random()*8)]));
					}
				}
                //console.log(arrows.length);
			}
		
			function globalRender(){
				context.clearRect(0,0,width,height);
				for(var j=0; j<arrows.length; j++){
					arrows[j].render();
				}
				requestAnimationFrame(globalRender);
			}

		
			function arrow(x_, y_, letter_){
				this.x = x_;
				this.y = y_;
				this.angle = 0;
				this.letter = letter_;
				this.dx, this.dy;
		
				this.render = function(){
					context.save();
					context.translate(this.x,this.y);
					context.rotate(this.angle);
			
					context.beginPath();
					switch(this.letter) {
					    case 'J':
					        context.moveTo(0,0);
					        context.lineTo(15,0);
					        context.lineTo(15,25);
					        context.lineTo(10,30);
					        context.lineTo(5,30);
					        context.lineTo(0,25);
					        break;
					    case 'O':
					        context.moveTo(15,5);
					        context.lineTo(15,25);
					        context.lineTo(10,30);
					        context.lineTo(5,30);
					        context.lineTo(0,25);
					        context.lineTo(0,5);
					        context.lineTo(5,0);
					        context.lineTo(10,0);
					        context.lineTo(15,5);
					        break;
					    case 'S':
					    	context.moveTo(15,5);
					    	context.lineTo(10,0);
					    	context.lineTo(5,0);
					    	context.lineTo(0,5);
					    	context.lineTo(0,10);
					    	context.lineTo(5,15);
					    	context.lineTo(10,15);
					    	context.lineTo(15,20);
					    	context.lineTo(15,25);
					    	context.lineTo(10,30);
					    	context.lineTo(5,30);
					    	context.lineTo(0,25);
					    	break;
					    case 'M':
					    	context.moveTo(0,30);
							context.lineTo(0,0);
							context.lineTo(10,10);
							context.lineTo(20,0);
							context.lineTo(20,30);
							break;
						case 'U':
							context.moveTo(0,0);
							context.lineTo(0,25);
							context.lineTo(5,30);
							context.lineTo(10,30);
							context.lineTo(15,25);
							context.lineTo(15,0);
							break;
						case 'R':
							context.moveTo(0,0);
							context.lineTo(0,30);
							context.moveTo(0,0);
							context.lineTo(10,0);
							context.lineTo(15,5);
							context.lineTo(15,10);
							context.lineTo(10,15);
							context.lineTo(15,20);
							context.lineTo(15,30);
							context.moveTo(0,15);
							context.lineTo(10,15);
							break;
					    default:
					    	// 'H'
					        context.moveTo(0,0);
					        context.lineTo(0,30);
					        context.moveTo(0,15);
					        context.lineTo(15,15);
					        context.moveTo(15,0);
					        context.lineTo(15,30);
					}
					context.stroke();
					context.restore();
				}
			}
		
			document.body.addEventListener("mousemove",function(event){
				for(var k=0; k<arrows.length; k++){
					arrows[k].dx = event.clientX - arrows[k].x;
					arrows[k].dy = event.clientY - arrows[k].y;
					arrows[k].angle = Math.atan2(arrows[k].dy,arrows[k].dx);
				}
			});
		};
