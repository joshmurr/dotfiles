const playButton = document.getElementById('playButton');
//create a maximilian object
var maxi = maximilian();

//create an audio engine
var maxiEngine = new maxi.maxiAudio();

//create two oscillators
var osc0 = new maxi.maxiOsc();
var osc1 = new maxi.maxiOsc();
var osc2 = new maxi.maxiOsc();
var osc3 = new maxi.maxiOsc();
var osc4 = new maxi.maxiOsc();
var osc5 = new maxi.maxiOsc();
var osc6 = new maxi.maxiOsc();
var osc7 = new maxi.maxiOsc();
var osc8 = new maxi.maxiOsc();
var loPassPhasor = new maxi.maxiOsc();
var filter = new maxi.maxiFilter();
var loFilter = new maxi.maxiFilter();
var loFilter2 = new maxi.maxiFilter();
var hiFilter = new maxi.maxiFilter();
var delay = new maxi.maxiDelayline();
var ticker = new maxi.maxiOsc();

var drums = [2, 4, 8, 16];
var bassTone;

var oscilloscope,spectrogram;
var tick, lastTick, counter = 0;

//when the play button is pressed...
let playAudio = () => {

    //arrange play button
    playButton.style.display="none";
    //start the audio engine

    maxiEngine.init();
    //maxiEngine.outputIsArray(true, 2);
    //show an oscilloscope and freqscope
    Nexus.context = maxiEngine.context;
    oscilloscope = new Nexus.Oscilloscope('oscilloscope', {'size': [600,200]}).connect(maxiEngine.maxiAudioProcessor);
    spectrogram = new Nexus.Spectrogram('spectrogram', {'size': [600,200]}).connect(maxiEngine.maxiAudioProcessor);

    maxiEngine.play = function() {
        let oscFreq = osc0.phasor(0.005); // Sets the main build up speed
        let bassOsc = osc3.coswave(0.5) + 1;
        let bassAmp = osc1.phasor(0.5, 0.1, 0.9);
        let n = osc7.noise();

        tick = Math.floor(ticker.phasor(oscFreq * 10)); // Tick every second
        if(lastTick != tick){
            bassTone = drums[counter % 4] * 0.02;
            //console.log(bassTone);
            counter++;
            lastTick = 0;
        }

        let s = osc6.sinewave(oscFreq * n) * 0.5;
        let s2 = osc5.sinewave(bassOsc+80) * bassAmp;

        let b = osc4.coswave(220) * bassTone; // Arpeggiator sort of thing

        let del = (s + (delay.dl(s, 14000, 0.9) * 0.5))/2; // Add delay to the saw wave click

        let lo_b_phasor = ((loPassPhasor.phasor(bassOsc) * 440) + 440)/2; // A value between 220 and 440 (I think)

        let lo_s2 = loFilter.lores(s2, 440, 80);
        let lo_s3 = loFilter.lores(s2, lo_b_phasor, 180);

        let lo_b = loFilter2.lores(b, 330, 100);
        let hi_b = hiFilter.hires(b, 1200, 10);

        let w = (s + lo_s2 + lo_s3 + b + lo_b + hi_b  + del) * 0.3;

        return w;
    }
}

playButton.addEventListener("click", () => playAudio());
