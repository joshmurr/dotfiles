using System.Collections;
using System.Collections.Generic;
using Sanford.Multimedia.Midi;
using UnityEngine;
using UnityEngine.Events;

public abstract class ForestElement : MonoBehaviour
{
    public int elementID;
    public UnityEvent onGetActive;
    public UnityEvent onGetInactive;
    public UnityEvent onLightShow1;
    public UnityEvent onLightShow2;
    public UnityEvent onLightShow3;

    // OSC:
    public osc_sender sender;
    public int id;
    public string type;
    public string osc_address;
    
    protected ForestDirector _director;
    public enum ElementStates
    {
        inactive,
        active,
        special1,
        special2,
        special3
    }

    protected ElementStates _currentState;

    //object initialisation. Explicitly called by the director to initialise the ForestElement
    public virtual void Init(ForestDirector fd, int _id=0, string type="")
    {
        //sending a reference to the director
        if (_director==null)
            _director = fd;
        //making sure the trees are inactive
        ChangeState(ElementStates.inactive);
        //TODO other init thingies
        id = _id;
        osc_address = type + '_' + id;
        //Debug.Log("This elem osc_address is: " + osc_address);

    }

    public virtual void SetupOSC(){
        //sender._udpPort = 7700;
        //sender._oscAddress = osc_address;
    }

    UnityEvent m_MyEvent;//test event 
    /*public void OnEnable()
    {
        //testing to make sure no bugs later 
        if (m_MyEvent == null) {
            m_MyEvent = new UnityEvent(); //adding event 
            m_MyEvent.AddListener(Ping); //adding listener to function 
        }
    }*/

    void Ping() //function called by m_MyEvent 
    {
        Debug.Log("Ping"); 
    }
    
    public virtual void OnDisable()
    {
        onGetActive.RemoveAllListeners();
        onGetInactive.RemoveAllListeners();
        onLightShow1.RemoveAllListeners();
        onLightShow2.RemoveAllListeners();
        onLightShow3.RemoveAllListeners();
    }
    
    void Update()
    {
        EvaluateState();
        /*if (Input.anyKeyDown && m_MyEvent != null) {
            m_MyEvent.Invoke();

            ChangeState(ElementStates.active);
        }*/
    }

    void EvaluateState()
    {
        switch (_currentState)
        {
            case ElementStates.active:
                //when gets activated, notifies the director.
                RunActive();
                break;

            case ElementStates.inactive:
                //when gets inactive, notifies the director.
                RunInactive();
                break;

            case ElementStates.special1:
                RunSpecial1();
                break;

            case ElementStates.special2:
                RunSpecial2();
                break;

            case ElementStates.special3:
                RunSpecial3();
                break;
        }
    }

    public void ChangeState (ElementStates state)
    {
        //transitions are public events any monobehaviour can subscribe to.
        //These are called only once when the state changes.
        switch (state)
        {
            case ElementStates.active:
                onGetActive.Invoke();
                break;
            case ElementStates.inactive:
                onGetInactive.Invoke();
                break;
            case ElementStates.special1:
                onLightShow1.Invoke();
                break;
            case ElementStates.special2:
                onLightShow2.Invoke();
                break;
            case ElementStates.special3:
                onLightShow3.Invoke();
                break;
        }
        _currentState = state;
    }


    //abstract classes to implement the various states. They are run on update.
    public abstract void RunActive();
    public abstract void RunInactive();
    public abstract void RunSpecial1();
    public abstract void RunSpecial2();
    public abstract void RunSpecial3();
    

}
