uniform vec2 u_resolution;
uniform float u_time;

void main(){
    vec2 p = gl_FragCoord.xy / u_resolution.xy;
    vec2 q = p - vec2(0.4+sin(u_time)*0.01, 0.6);

    vec3 col = mix(vec3(1.0, 0.3, 0.0), vec3(1.0, 0.8, 0.3), sqrt(p.y));

    // Palm Tree Top
    float r = 0.2 + 0.1*cos(u_time + atan(q.y, q.x)*10.0 + q.x*25.0);
    col *= smoothstep(r, r+0.02, length(q));

    // Trunk
    r = 0.015;
    r += 0.002*cos(120.0*q.y);
    r += exp(-70.0*p.y);
    col *=  1.0 - (1.0-smoothstep(r, r+0.01, abs(q.x-0.2*sin(2.0*q.y))))*(1.0-smoothstep(0.0, 0.1, q.y));

    gl_FragColor = vec4(col, 1.0);
}
