html, body{
	padding: 0px;
	margin: 0px;
}

#left{
	position: absolute;
	width: 50%;
	height: 100%;
	text-align: center;
	display: table;
	overflow: hidden;
}

#right{
	position: absolute;
	margin-left: 50%;
	/*background-color: black;*/
	/*opacity: 0;*/
	width: 50%;
	height: 100%;
	color: white;
	overflow: hidden;
}

#canvas{
	display: block;
	position: absolute;
	top: 0;
	left: 0;
}

#container{
	position: absolute;
	width: 150px;
	/*height: 70px;*/
	background-color: black;
}

#name{
	color: white;
	height: 20px;
	top: 0;
	left: 0;
}

.half{
	width: 50%;
	float: left;
	text-align: center;
	padding-top: 60px;
}

.half img{
	padding-bottom: 20px;
	max-width: 100%;
}

h1, h2{
	font-family: Monaco, "Lucida Console", monospace;
	font-weight: normal;
	line-height: 15px;
    display:block;
}

h1{
	vertical-align: middle;
	font-size: 12px;
}

h2{
	font-size: 10px;
	padding: 2px 0;
	margin: 0;
}



#right_holder{
	position: absolute;
	padding: 20px;
	width: 170px;
	height: 412px;
	margin: -206px 0 0 -100px;
	left: 50%;
	top: 50%;
	background-color: black;
	/*border: 1px solid red;*/
}



a {
	text-decoration: none;
	color: white;
}

a:hover{
	color: lightgrey;
}

