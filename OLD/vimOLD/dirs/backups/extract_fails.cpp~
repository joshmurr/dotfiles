#include <list>
#include "grade.h"
#include "extract_fails.h"

using std::vector;
using std::list;

// Using Lists, which are better optimised for random removal

list<Student_info> extract_fails(list<Student_info>& students){
    list<Student_info> fail;
    list<Student_info>::iterator iter = students.begin(); //.begin() returns an iterator

    while(iter != students.end()){ // .end() also returns an iterator
        if(fgrade(*iter)) { // dereference iterator (the student in the vector)
            fail.push_back(*iter);
            // Means of accessing vector at i using erase (?)
            iter = students.erase(iter); // .erase(iter) returns next item (iterator) in vector
        } else
            ++iter;
    }
    return fail;
}

