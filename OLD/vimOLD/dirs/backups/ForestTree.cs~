using System;
using System.Collections;
using System.Collections.Generic;
using UnityEngine;

public class ForestTree : ForestElement
{
    private AudioSource _audio;

    public AudioClip failAudio;
    public AudioClip activeAudio;

    
    //just for test
    private SpriteRenderer _sprite;
    public float coolDownTime=5;
    private float _timer;

    private bool WIN = false;
    private bool LOSE = false;

    void Start(){
    }

    void OnEnable()
    {
        //base.OnEnable();
        onGetActive.AddListener(Activate);
        onGetInactive.AddListener(Deactivate);
        onLightShow1.AddListener(Special1);
        onLightShow2.AddListener(Special2);
        
        _audio = GetComponent<AudioSource>();
        //just for test
        _sprite = GetComponent<SpriteRenderer>();
        //sender._oscAddress = osc_address;
    }


    //onDisable listener remove is on the ForestElement class
    
    //update methods depending on state
    public override void RunActive() {
        
    }

    public override void RunInactive()
    {

    }

    public override void RunSpecial1()
    {

    }

    public override void RunSpecial2()
    {
        if (_timer >= coolDownTime)
        {
            //not ideal bc all the tree will call InitTreeGame at once, but works, so.
            _director.InitTreeGame();
        }
        _timer += Time.deltaTime;
    }

    public override void RunSpecial3()
    {

    }

    void Activate()
    {

        //_director.TreeActiveState(elementID, true);
        _sprite.color = Color.green;
        sender.SendDataTo(100, "clear");
        Debug.Log("Sending data to: "+ osc_address);
        sender.SendDataTo(100, osc_address);
    }

    void Deactivate()
    {
        //_director.TreeActiveState(elementID, false);
        //check if I'm not playing the fail audio
        if (_audio.clip == activeAudio)
        {
            _audio.loop = false;
            _audio.Stop();
        }
        _sprite.color = Color.grey;
    }

    void Special1()
    {
        _sprite.color = Color.white;
        //Re-send address to turn off the light.
        //sender.SendDataTo(100, osc_address);
        PlayActiveAudio();
    }

    void Special2()
    {
        Debug.Log("Special2!");
        _sprite.color = Color.red;
        sender.SendDataTo(100, "winner");
        WIN = true;
        _timer = 0;
    }

    public void PlayFailAudio()
    {
        _audio.loop = false;
        _audio.clip = failAudio;
        _audio.Play();
    }

    public void PlayActiveAudio()
    {
        _audio.loop = true;
        _audio.clip = activeAudio;
        _audio.Play();
    }
    
    //Only For Test
    private void OnMouseDown()
    {
        switch (_currentState)
        {
            case ElementStates.active:
                ChangeState(ElementStates.special1);
                _director.NextTree();
                break;
            case ElementStates.special2:

                break;
            default:
                // play fail audio
                PlayFailAudio();
                sender.SendDataTo(100, "loser");
                //tell director that I pressed the wrong one
                _director.InitTreeGame();
            break;
            
        }
    }
}
