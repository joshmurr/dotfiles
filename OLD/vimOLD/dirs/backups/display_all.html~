{% extends "display.html" %}

{% block display %}

<!-- DISPLAY ALL -->

<div class="row">
    <table class="table table-striped table-hover">
        <thead data-ng-init="getAllEntries()">
            <tr>
                <th>Website</th>
                <th>Most Used Word</th>
                <th>Count</th>
            </tr>
        </thead>
        {% raw %}
        <tbody>
            <tr ng-repeat="item in rows" ng-click="toggle_selected(item)" ng-class="{'table-info': item.id === selected_item.id}">
                <td>{{ item.url }}</td>
                <td>{{ item.top_word }}</td>
                <td>{{ item.frequency }}</td>
            </tr>
        </tbody>

    </table>
</div>
<div class="row" >
    <div class="container" ng-if="selected_item">
        <span ng-repeat="word in selected_item.words">{{ word }} |  </span>  
    </div>
</div>
<br>
<!-- TODO -->
<!-- Delete data instead of getData() -->
<form class="form-inline" ng-submit="delete()" method="get" ng-if="selected_item">
    <div class="input-group col-sm">
        <div class="input-group-prepend">
            <span class="input-group-text" id="inputGroupPrepend">Item:</span>
        </div>
        <input ng-model="id_box" class="form-control" type="text" id="validationCustomUsername" aria-describedby="inputGroupPrepend" name="id">
        <div class="input-group col-sm">
            <button class="btn btn-primary" type="submit" ng-click="setSubmitType('delete')">Delete</button>
        </div>
    </div>
</form>
{% endraw %}

{% endblock %}
