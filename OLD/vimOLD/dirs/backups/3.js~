const playButton = document.getElementById('playButton');
const randButton = document.getElementById('randButton');
const controls = document.getElementById('controls');
//create a maximilian object
var maxi = maximilian();

//create an audio engine
var maxiEngine = new maxi.maxiAudio();

var oscillators;
var oscCount=100;

var oscilloscope,spectrogram;


function randomise() {
    console.log("Randomising");
    oscillators = new Array(oscCount);
    for(let i=0; i<oscCount; i++){
        oscillators[i] = {
            osc: new maxi.maxiOsc(),
            freq: (Math.pow(Math.random(),2) * 15000) + 40,
            amp: Math.pow(Math.random(), 2)
        };

        oscillators[i].osc.phaseReset(Math.random());
    }
}

//when the play button is pressed...
let playAudio = () => {
    //arrange play button
    playButton.style.display="none";
    controls.style.display="block";

    //start the audio engine
    maxiEngine.init();

    randomise();

    //maxiEngine.outputIsArray(true, 2);
    //show an oscilloscope and freqscope
    Nexus.context = maxiEngine.context;
    oscilloscope = new Nexus.Oscilloscope('oscilloscope', {'size': [900,200]}).connect(maxiEngine.maxiAudioProcessor);
    spectrogram = new Nexus.Spectrogram('spectrogram', {'size': [900,200]}).connect(maxiEngine.maxiAudioProcessor);
    var number = new Nexus.Number('#oscCountControl',{
        'size': [60, 30],
        'value': 100,
        'min': 2,
        'max': 5000,
        'step': 1
    })
    number.on('change', function(v) {
        oscCount = v;
        randomise();
    })

    maxiEngine.play = function() {
        var w = 0;
        for(let i=0; i<oscillators.length; i++){
            w += (oscillators[i].osc.coswave(oscillators[i].freq) * oscillators[i].amp);
        }
        w /= Math.sqrt(oscillators.length);
        return w;
    }
}

playButton.addEventListener("click", () => playAudio());
randButton.addEventListener("click", () => randomise());
