const playButton = document.getElementById('playButton');
const controls = document.getElementById('controls');
const ampBox = document.getElementById('ampBox');
const freqBox = document.getElementById('freqBox');
const multiplierBox = document.getElementById('multiplierBox');
//create a maximilian object
var maxi = maximilian();

//create an audio engine
var maxiEngine = new maxi.maxiAudio();
var oscilloscope,spectrogram;

var user_frequency = 100;
var user_multiplier = 1;
var user_amp = 1;
var osc1 = new maxi.maxiOsc();
var osc2 = new maxi.maxiOsc();

//when the play button is pressed...
let playAudio = () => {
    //arrange play button
    playButton.style.display="none";
    controls.style.display="block";

    //start the audio engine
    maxiEngine.init();

    //show an oscilloscope and freqscope
    Nexus.context = maxiEngine.context;
    oscilloscope = new Nexus.Oscilloscope('oscilloscope', {'size': [900,200]}).connect(maxiEngine.maxiAudioProcessor);
    spectrogram = new Nexus.Spectrogram('spectrogram', {'size': [900,200]}).connect(maxiEngine.maxiAudioProcessor);

    // Get Amp from box
    var frequency = new Nexus.Number(freqBox,{
        'size': [60, 30],
        'value': 1,
        'min': 0,
        'max': 18000,
        'step': 1
    })
    frequency.on('change', function(v) {
        user_frequency = v;
    })
    
    // Get 2nd Frequency from box
    var multipler = new Nexus.Number(multiplierBox,{
        'size': [60, 30],
        'value': 1,
        'min': 0,
        'max': 10,
        'step': 0.1
    })
    multipler.on('change', function(v) {
        user_multiplier = v;
    })
    
    // Get AMP
    var amp = new Nexus.Number(ampBox,{
        'size': [60, 30],
        'value': 1,
        'min': 0,
        'max': 10,
        'step': 0.1
    })
    amp.on('change', function(v) {
        user_amp = v;
    })



    maxiEngine.play = function() {
        return (osc1.sinewave(user_frequency) + osc2.sinewave(user_frequency * user_multiplier)) * user_amp; 
    }
}

playButton.addEventListener("click", () => playAudio());
