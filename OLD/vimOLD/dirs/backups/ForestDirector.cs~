    #region  TreeMiniGame

    /*The tree minigame is done this way: we have an ordered list of trees.
    thye light up one at a time to signal they can be activated. When the button on a lit tree is pressed,
    it gets to a small animation and the next in line is lit up. States will be used this way:
    - Inactive: this tree is currently off and if pressed it resets the minigame
    - Active: this tree is lit. It takes input from the players and if so moves to the next one.
    - Special 1: when the tree has taken input it's doing a little looping animation
    */
    
    //Here we put a list of all trees. The sequence is the order of trees in the list.
    //The list NEEDS to be populated :)
    [Header("Tree Game List")]
    public List<ForestTree> forestTrees;
    public int counter = 0;
    private int i;
    
    public void InitTreeGame()
    {
        //forestTrees.Clear();
        i = 0; 
        //resetting all tree states
        foreach (ForestTree t in forestTrees)
        {
            t.ChangeState(ForestElement.ElementStates.inactive);
            t.Init(this, i++, "tree");
        }
        //setting the first tree active
        forestTrees[0].ChangeState(ForestElement.ElementStates.active);
        counter = 0;
        _audio.Stop();

        Debug.Log("forestTrees length: " + forestTrees.Count);
    }

    //this gets called by the tree if the button is pressed when it's active
    public void NextTree()
    {
        
        if (counter == forestTrees.Count-1)
        {
            
            //all the trees do a light show then get back to all inactive
            foreach (ForestTree t in forestTrees)
            {
                t.ChangeState(ForestElement.ElementStates.special2);
            }

            _audio.clip = treeGameWin;
            _audio.loop = true;
            _audio.Play();
        }
        else
        {
            counter++;
            forestTrees[counter].ChangeState(ForestElement.ElementStates.active);
        }
    }
    
