using System.Collections;
using System.Collections.Generic;
using UnityEngine;

public class Tree : ForestElement
{
    // The shape and color rendered in Unity
    SpriteRenderer m_sprite;
    Color activeColor = new Color(214, 233, 164, 255);
    Color inactiveColor = new Color(164, 216, 233, 255);

    void Start(){
        //Fetch the SpriteRenderer from the GameObject
        m_sprite = GetComponent<SpriteRenderer>();
        //Set the GameObject's Color quickly to a set Color (blue)
        m_sprite.color = inactiveColor;
    }
    
    void OnEnable()
    {
        //base.OnEnable();
        onGetActive.AddListener(Activate);
        onGetInactive.AddListener(Deactivate);
    }

    void OnDisable()
    {
        onGetActive.RemoveAllListeners();
        onGetInactive.RemoveAllListeners();
    }


    
    //update methods depending on state
    public override void RunActive() {
        m_sprite.color = activeColor;
        
    }

    public override void RunInactive() {
        //m_sprite.color = inactiveColor;

    }

    public override void RunSpecial1()
    {

    }

    public override void RunSpecial2()
    {

    }

    public override void RunSpecial3()
    {

    }

    void Activate()
    {
        _director.TreeActiveState(elementID, true);
        Debug.Log("Active!");
    }

    void Deactivate()
    {
        _director.TreeActiveState(elementID, false);
    }
}
