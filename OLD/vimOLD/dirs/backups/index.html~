                                    for (var i = 0; i < dim; i++) {                
                                      var z = size * Math.cos(spacing / 2 * i);
                                      var s = size * Math.sin(spacing / 2 * i);
                                          for (var j = 0; j < dim; j++ ) {
                                          var point = [
                                              cos(spacing * j) * s, 
                                              sin(spacing * j) * s, 
