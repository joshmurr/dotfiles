#include <stdio.h>
#include <unistd.h>

int main(int argc, char* argv[]){
    char data;
    if(argc != 2) {
        printf("Usage: ./a.out n | f\n");
        return 1;
    } else {
        data = *argv[1];
        printf("Sending %c to the Arduino\n", data);
    }
    FILE *arduino_stream;
    arduino_stream = fopen("/dev/cu.usbmodem14201", "w");
    int i=0;
    fprintf(arduino_stream, "%c", data);
    fclose(arduino_stream);
    return 0;
}
