#include <iostream>
#include <vector>
using namespace std;

void print(vector<int>* v){
    for(unsigned int n=0; n<v->size(); n++){
        cout << v->at(n) << " ";
        cout << endl;
    }
}

int main(){
    int _primes[] = {2,3,5,6};
    int _fibonaccis[] = {1,1,2,3};

    vector<int> primes(_primes, _primes+8);
    vector<int> fibonnacis(_fibonaccis, _fibonaccis+8);

    print(&primes);
    cout << endl;
    print(&fibonnacis);
    return 0;
}
