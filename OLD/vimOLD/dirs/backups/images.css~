.image-grid .row {
  display: flex;
  flex-wrap: wrap;
  padding: 0px;
}

/* Create four equal columns that sits next to each other */
.image-grid .column {
  flex: 25%;
  max-width: 24%;
  padding: 0 4px;
}

.image-grid .column img {
  margin-top: 16px;
  margin-bottom: 0px;
  vertical-align: middle;
  width: 100%;
}

/* Create two equal columns that sits next to each other */
.image-grid .column-2 {
  flex: 50%;
  max-width: 48%;
  padding: 0 4px;
}

.image-grid .column-2 img {
  margin-top: 16px;
  margin-bottom: 0px;
  vertical-align: middle;
  width: 100%;
}

/* Create THREE equal columns that sits next to each other */
.image-grid .column-3 {
  flex: 33.3%;
  max-width: 32%;
  padding: 0 4px;
}

.image-grid .column-3 img {
  margin-top: 16px;
  margin-bottom: 0px;
  vertical-align: middle;
  width: 100%;
}

@media screen and (max-width: 1200px) {
 .image-grid .column {
    flex: 50%;
    max-width: 50%;
  }
}
/* Responsive layout - makes a two column-layout instead of four columns */
@media screen and (max-width: 800px) {
 .image-grid .column {
    flex: 50%;
    max-width: 50%;
  }
}

/* Responsive layout - makes the two columns stack on top of each other instead of next to each other */
@media screen and (max-width: 600px) {
 .image-grid .column {
    flex: 100%;
    max-width: 100%;
  }
}

.reveal section img {
    margin: 0px;
    width: 80%;
    background: rgba(0, 0, 0, 0);
}

.image-left{
    float: left;
    width: 50%;
    margin: 0px;
}

.image-caption > p > i {
    color: #00FF00;
}

i {
    font-style: italic;
}
