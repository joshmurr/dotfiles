const playButton = document.getElementById('playButton');
//create a maximilian object
var maxi = maximilian();

//create an audio engine
var maxiEngine = new maxi.maxiAudio();

//create two oscillators
var osc0 = new maxi.maxiOsc();
var osc1 = new maxi.maxiOsc();
var osc2 = new maxi.maxiOsc();
var osc3 = new maxi.maxiOsc();
var osc4 = new maxi.maxiOsc();
var osc5 = new maxi.maxiOsc();
var osc6 = new maxi.maxiOsc();
var filter = new maxi.maxiFilter();

var oscilloscope,spectrogram;

//when the play button is pressed...
let playAudio = () => {

      //arrange play button
      playButton.style.display="none";
      //start the audio engine

      maxiEngine.init();
      //maxiEngine.outputIsArray(true, 2);
      //show an oscilloscope and freqscope
      Nexus.context = maxiEngine.context;
      oscilloscope = new Nexus.Oscilloscope('oscilloscope', {'size': [600,200]}).connect(maxiEngine.maxiAudioProcessor);
      spectrogram = new Nexus.Spectrogram('spectrogram', {'size': [600,200]}).connect(maxiEngine.maxiAudioProcessor);

      maxiEngine.play = function() {
          let phasor1 = ((osc0.phasor(0.001) + 0.5) /2 ) * 2 + 10; // Slow ramp, at 0.01Hz = 100secs
          let phasor3 = osc6.phasor(0.1) + 0.5;
          let phasor4 = osc2.sinewave(phasor3 * 400) * 0.5;
          let phasor2 = (Math.pow(osc1.phasor(phasor4 * 0.000100) + 0.5), 2) * 0.5 - 1; // Faster ramp at 0.1Hz = 10sec

          let oscil = (osc5.coswave(440) + 0.5) * 0.25;
          let filterOsc = osc4.sinewave(oscil * 0.23);



          let w = ((osc2.sinewave(filterOsc * 0.04) * phasor1) + (osc3.sinewave(filterOsc * 0.002) + phasor2)) * 0.1;
          //w = filter.lores(w, 200, 0);
         
          //let w = (osc1.sawn(oscFreq) + osc2.sawn(oscFreq * 1.001)) * 0.5 
          //w = filter.lores(w, filterFreq, 8);
          return w;
      }
}

playButton.addEventListener("click", () => playAudio());
