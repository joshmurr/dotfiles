#include "Student_info.h"

using std::istream; using std::vector;


bool compare(const Student_info& x, const Student_info& y){
    // String compare operator (<) checks for alphabet order
    return x.name < y.name;
}


// Passes reference to cin and to hw so as to alter the originals
// Passes values from cin to hw
istream& read_hw(istream& in, vector<double>& hw){
    if(in){
        hw.clear();

        double x;
        while(in >> x) hw.push_back(x);

        in.clear();
    }
    return in;
}


istream& read(istream& is, Student_info& s){
    // Read and store student information
    is >> s.name >> s.midterm >> s.fin;
    read_hw(is, s.homework);
    return is;
}

bool fgrade(const Student_info& s){
    return grade(s)<60;
}
