const playButton = document.getElementById('playButton');
const controls = document.getElementById('controls');
const ampButton = document.getElementById('ampButton');
const innerFreqButton = document.getElementById('innerFreqButton');
const innerAmpButton = document.getElementById('innerAmpButton');
//create a maximilian object
var maxi = maximilian();

//create an audio engine
var maxiEngine = new maxi.maxiAudio();
var oscilloscope,spectrogram;

var user_amp = 1;
var user_inner_freq = 100;
var user_inner_amp = 1;
var osc  = new maxi.maxiOsc();
var inner_osc = new maxiOsc();

//when the play button is pressed...
let playAudio = () => {
    //arrange play button
    playButton.style.display="none";
    controls.style.display="block";

    //start the audio engine
    maxiEngine.init();

    //show an oscilloscope and freqscope
    Nexus.context = maxiEngine.context;
    oscilloscope = new Nexus.Oscilloscope('oscilloscope', {'size': [900,200]}).connect(maxiEngine.maxiAudioProcessor);
    spectrogram = new Nexus.Spectrogram('spectrogram', {'size': [900,200]}).connect(maxiEngine.maxiAudioProcessor);

    // Get Amp from box
    var amp = new Nexus.Number('#ampControl',{
        'size': [60, 30],
        'value': 1,
        'min': 0,
        'max': 10,
        'step': 0.1
    })
    amp.on('change', function(v) {
        user_amp = v;
    })
    
    // Get 2nd Frequency from box
    var inner_freq = new Nexus.Number('#innerFreqControl',{
        'size': [60, 30],
        'value': 100,
        'min': 0,
        'max': 22000,
        'step': 1
    })
    inner_freq.on('change', function(v) {
        user_inner_freq = v;
    })

    // Get Amp from box
    var inner_amp = new Nexus.Number('#innerAmpControl',{
        'size': [60, 30],
        'value': 1,
        'min': 0,
        'max': 10,
        'step': 0.1
    })
    inner_amp.on('change', function(v) {
        user_inner_amp = v;
    })


    maxiEngine.play = function() {
        return osc.sinewave(inner_osc.sinewave(user_inner_freq) * user_inner_amp) * user_amp; 
    }
}

playButton.addEventListener("click", () => playAudio());
