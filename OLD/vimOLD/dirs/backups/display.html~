{% extends "layout.html" %}

{% block main %}
<main ng-controller="DisplayResultsController" class="container p-5">
    <div class="container-fluid">
        <div class="row">
            <table class="table table-striped table-hover">
                <thead data-ng-init="getAllData()">
                    <tr>
                        <th>Website</th>
                        <th>Most Used Word</th>
                        <th>Count</th>
                        <th ng-show="single">Words</th>
                    </tr>
                </thead>
                {% raw %}
                <tbody ng-show="!single">
                    <tr ng-repeat="item in rows" ng-click="toggle_selected(item)" ng-class="{'table-info': item.id === selected_item.id}">
                        <td>{{ item.url }}</td>
                        <td>{{ item.top_word }}</td>
                        <td>{{ item.frequency }}</td>
                    </tr>
                </tbody>
                <tbody ng-show="single">
                    <td>{{ item.url }}</td>
                    <td>{{ item.top_word }}</td>
                    <td>{{ item.frequency }}</td>
                    <td><span ng-repeat="word in item.words">{{ word }}<br></span></td>
                </tbody>
            </table>
        </div>
        <form class="form-inline"  ng-submit="getData()" ng-if="selected_item">
            <div class="input-group col-sm">
                <div class="input-group-prepend">
                    <span class="input-group-text" id="inputGroupPrepend">Item:</span>
                </div>
                <input disabled class="form-control" type="text" id="validationCustomUsername" placeholder="www.url.com" aria-describedby="inputGroupPrepend" value="{{selected_item.url}}">
            </div>
            <div class="input-group col-sm">
                <button class="btn btn-primary" type="submit">View More</button>
            </div>
            <div class="input-group col-sm">
                <button class="btn btn-primary" type="submit">Delete</button>
            </div>
        </form>
        {% endraw %}
    </div>
</main>

{% endblock%}
