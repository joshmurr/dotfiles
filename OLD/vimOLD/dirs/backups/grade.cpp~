#include <stdexcept>
#include <vector>
#include "grade.h"
#include "median.h"
#include "Student_info.h"

using std::domain_error; using std::vector;


double grade(double midterm, double fin, double homework){
    return 0.2*midterm + 0.4*fin + 0.4*homework;
}


// Passes a reference to the original vector so as to call .size()
// without needing to copy it (creating overheads).
// Use of const to prevent altering of original.
double grade(double midterm, double fin, const vector<double>& hw){
    if(hw.size() == 0) throw domain_error("student has done no homework");
    return grade(midterm, fin, median(hw));
}


double grade(const Student_info& s){
    return grade(s.midterm, s.fin, s.homework);
}
