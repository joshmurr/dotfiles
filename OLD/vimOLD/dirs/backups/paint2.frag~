#ifdef GL_ES
precision mediump float;
#endif

#define PI 3.14159265359

uniform vec2 u_mouse;
uniform vec2 u_resolution;
uniform float u_time;


vec3 red = vec3(1.0, 0.0, 0.0);
vec3 green = vec3(0.0, 1.0, 0.0);
vec3 blue = vec3(0.0, 0.0, 1.0);

void main(){
    vec2 p = gl_FragCoord.xy / u_resolution;

    vec3 y_gradient = vec3(p.y);

    y_gradient.r = sin(p.y * PI);
    y_gradient.g = pow(p.y,0.2);
    y_gradient.b = pow(sin(p.y * PI*2.0),2.0);

    vec3 x_gradient = vec3(p.x);

    x_gradient.r = smoothstep(0.0, 1.0, pow(p.x,2.0));
    x_gradient.g = pow(p.x,0.2);
    x_gradient.b = sqrt(abs(sin(p.x * PI*2.0)));


    vec3 o1 = mix(blue, red, y_gradient);
    vec3 o2 = mix(green, blue, x_gradient);

    vec3 o = mix(o1, o2, atan(p.y,p.x));

    gl_FragColor = vec4(o, 1.0);

}
