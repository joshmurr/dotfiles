import operator
from app import db
from sqlalchemy.dialects.postgresql import JSON


class Result(db.Model):
    __tablename__ = 'results'

    id = db.Column(db.Integer, primary_key=True)
    url = db.Column(db.String())
    result_all = db.Column(JSON)
    result_no_stop_words = db.Column(JSON)

    def __init__(self, url, result_all, result_no_stop_words):
        self.url = url
        self.result_all = result_all
        self.result_no_stop_words = result_no_stop_words

    def __repr__(self):
        return '<id {}>'.format(self.id)

    def serialize(self):
        top_word_amount = sorted(
                self.result_no_stop_words.items(),
                key=operator.itemgetter(1),
                reverse=True
                )[0]
        return {
                'id': self.id,
                'url': self.url,
                'top_word': top_word_amount[0],
                'frequency': top_word_amount[1]
                }

    def serialize_full(self):
        top_word_amount = sorted(
                self.result_no_stop_words.items(),
                key=operator.itemgetter(1),
                reverse=True
                )[:10]
        return {
                'id': self.id,
                'url': self.url,
                'top_word': top_word_amount[0][0],
                'frequency': top_word_amount[0][1],
                'words': [word for word in top_word_amount[0]]
                }

