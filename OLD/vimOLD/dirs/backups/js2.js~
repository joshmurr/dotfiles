import * as THREE from 'https://unpkg.com/three@0.108.0/build/three.module.js';
import {GUI} from 'https://threejsfundamentals.org/threejs/../3rdparty/dat.gui.module.js';
import {OrbitControls} from 'https://threejsfundamentals.org/threejs/resources/threejs/r110/examples/jsm/controls/OrbitControls.js';



function main(){
    const canvas = document.querySelector('#c');
    const renderer = new THREE.WebGLRenderer({canvas});
    renderer.shadowMap.enabled = true;

    const gui = new GUI();

    const fov = 80;
    const aspect = 3;
    const near = 10;
    const far = 300;

    const scene = new THREE.Scene();
    scene.fog = new THREE.Fog('black', 20, 200);

    const objects = [];

    const camera = new THREE.PerspectiveCamera(fov, aspect, near, far);
    camera.position.set(0, 30, 100);

    const controls = new OrbitControls(camera, canvas);
    controls.target.set(0, 0, 0);
    controls.update();

    // CLASSES ***********************************************************//
    class MinMaxGUIHelper {
        constructor(obj, minProp, maxProp, minDif) {
            this.obj = obj;
            this.minProp = minProp;
            this.maxProp = maxProp;
            this.minDif = minDif;
        }
        get min() {
            return this.obj[this.minProp];
        }
        set min(v) {
            this.obj[this.minProp] = v;
            this.obj[this.maxProp] = Math.max(this.obj[this.maxProp], v + this.minDif);
        }
        get max() {
            return this.obj[this.maxProp];
        }
        set max(v) {
            this.obj[this.maxProp] = v;
            this.min = this.min;  // this will call the min setter
        }
    }

    class ColorGUIHelper{
        constructor(object, prop){
            this.object = object;
            this.prop = prop;
        }
        get value(){
            return `#${this.object[this.prop].getHexString()}`;
        }
        set value(hexString){
            this.object[this.prop].set(hexString);
        }
    }

    class SolarSystem{
        offsetRadius = (Math.random() * 100) + 5;
        solarSystem = new THREE.Object3D();
        objects = [];
        radius = 1;
        widthSegments = 6;
        heightSegments = 6;
        sphereGeometry = new THREE.SphereBufferGeometry(this.radius, this.widthSegments, this.heightSegments);

        constructor(numPlanets){
            this.numPlanets  = numPlanets;
            this.objects.push(this.solarSystem);
            this.makeSun();
            this.makePlanet();
            this.makePlanetWithMoon();
        }
        get system(){
            return this.solarSystem;
        }
        get objects(){
            return this.objects;
        }

        makeSun(){
            const sunMaterial = new THREE.MeshPhongMaterial({
                emissive: new THREE.Color("hsl(" + Math.floor(Math.random() * 64) + ", 100%, 50%)")
            });
            const sunMesh = new THREE.Mesh(this.sphereGeometry, sunMaterial);
            const scale = (Math.random() * 5) + 1;
            sunMesh.scale.set(scale, scale, scale);
            this.solarSystem.add(sunMesh);
            this.objects.push(sunMesh);
        }
        makePlanet(){
            const planetOrbit = new THREE.Object3D();
            planetOrbit.position.x = (Math.random() * 20)+4;
            planetOrbit.rotation.y = (Math.random() * Math.PI*2);
            this.solarSystem.add(planetOrbit);
            this.objects.push(planetOrbit);

            const planetMaterial = new THREE.MeshPhongMaterial({
                color: new THREE.Color("hsl(" + (Math.random() * 89)+23 + ", 100%, 50%)"), 
                emissive: 0x112244
            });
            const planetMesh = new THREE.Mesh(this.sphereGeometry, planetMaterial);
            planetOrbit.add(planetMesh);
            this.objects.push(planetMesh);
        }

        makePlanetWithMoon(){
            const planetOrbit = new THREE.Object3D();
            planetOrbit.position.x = (Math.random() * 10)+4;
            this.solarSystem.add(planetOrbit);
            this.objects.push(planetOrbit);

            const planetMaterial = new THREE.MeshPhongMaterial({color: 0x2233FF, emissive: 0x112244});
            const planetMesh = new THREE.Mesh(this.sphereGeometry, planetMaterial);
            planetOrbit.add(planetMesh);
            this.objects.push(planetMesh);

            const moonOrbit = new THREE.Object3D();
            moonOrbit.position.x = (Math.random() * 2) + 1;
            planetOrbit.add(moonOrbit);

            const moonMaterial = new THREE.MeshPhongMaterial({color: 0x888888, emissive: 0x222222});
            const moonMesh = new THREE.Mesh(this.sphereGeometry, moonMaterial);
            moonMesh.scale.set(.5, .5, .5);
            moonOrbit.add(moonMesh);
            this.objects.push(moonMesh);

        }
    }
    // **************************************************************************//

    // ICOSAHEDRON SKY
    const loader = new THREE.TextureLoader();
    const starrysky = loader.load('./starrysky.jpeg');
    starrysky.wrapS = THREE.RepeatWrapping;
    starrysky.wrapT = THREE.RepeatWrapping;
    const icosRad = 150;
    const icosGeo = new THREE.IcosahedronBufferGeometry(icosRad, 0);
    const icosMat = new THREE.MeshLambertMaterial({
        //color: new THREE.Color("hsl(0, 0%, 30%)"),
        map: starrysky,
        side: THREE.BackSide
    });
    const icosMesh = new THREE.Mesh(icosGeo, icosMat);
    icosMesh.receiveShadow;
    scene.add(icosMesh);

    // GALAXY
    const galaxy = new THREE.Object3D();
    scene.add(galaxy);

    for(let i=0; i<3; i++){
        const solarSystem = new SolarSystem(0);
        const system = solarSystem.system;
        const sys_objects = solarSystem.objects;
        system.position.x = solarSystem.offsetRadius * Math.cos(solarSystem.offsetRadius);
        system.position.y = solarSystem.offsetRadius * Math.sin(solarSystem.offsetRadius);
        system.position.z = solarSystem.offsetRadius * Math.sin(solarSystem.offsetRadius);
        galaxy.add(system);
        sys_objects.forEach((obj) => {
            objects.push(obj);
        });
    }




    const color = 0xFFFFFF;
    const intensity = 0.39;
    const light = new THREE.PointLight(color, intensity);
    light.position.set(0, 20, 62);
    light.castShadow = true;
    scene.add(light);


    const helper = new THREE.PointLightHelper(light);
    //scene.add(helper);


    function makeXYZGUI(gui, vector3, name, limit, onChangeFn){
        const folder = gui.addFolder(name);
        folder.add(vector3, 'x', -limit, limit).onChange(onChangeFn);
        folder.add(vector3, 'y', 0, limit).onChange(onChangeFn);
        folder.add(vector3, 'z', -limit, limit).onChange(onChangeFn);
        folder.open();
    }

    function updateCamera(){
        camera.updateProjectionMatrix();
    }

    function updateLight(){
        helper.update();
    }
    updateLight();

    const minMaxGUIHelper = new MinMaxGUIHelper(camera, 'near', 'far', 1);
    gui.addColor(new ColorGUIHelper(light, 'color'), 'value').name('color');
    gui.add(light, 'intensity', 0, 2, 0.01);
    gui.add(camera, 'fov', 1, 180).onChange(updateCamera);
    gui.add(minMaxGUIHelper, 'min', 1, 100, 1).name('near').onChange(updateCamera);
    gui.add(minMaxGUIHelper, 'max', 1, 500, 1).name('far').onChange(updateCamera);


    makeXYZGUI(gui, light.position, 'light pos', 100, updateLight);
    makeXYZGUI(gui, camera.position, 'camera pos', 300, updateCamera);

    function resizeRendererToDisplaySize(renderer){
        const canvas = renderer.domElement;
        const width = canvas.clientWidth;
        const height = canvas.clientHeight;
        const needResize = canvas.width !== width || canvas.height !== height;
        if(needResize){
            renderer.setSize(width, height, false);
        }
        return needResize;
    }

    function render(time){
        time *= 0.001;

        if(resizeRendererToDisplaySize(renderer)){
        const canvas = renderer.domElement;
            camera.aspect = canvas.clientWidth / canvas.clientHeight;
            camera.updateProjectionMatrix();
        }

        objects.forEach((obj, ndx) => {
            const u = ndx/objects.length;
            const speed = time * .005;
            const angle = speed + u * Math.PI*2 * (ndx % 1 ? 1 : -1);
            const radius = Math.sin(speed - ndx) * 80;
            obj.rotation.y = Math.sin(angle)*radius;

        });

        icosMesh.rotation.y = time/20;
        galaxy.rotation.y = time/10;
        renderer.render(scene, camera);
        requestAnimationFrame(render); 
    }
    requestAnimationFrame(render);

}

main();
